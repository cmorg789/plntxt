:80 {
    root * /srv/public
    file_server

    # rate limit auth endpoints
    @auth path /signup /signin
    # rate_limit @auth {remote.ip} 5r/m

    # rate limit API
    @api path /sql /rpc
    # rate_limit @api {remote.ip} 30r/s

    # NOTE: rate_limit directives commented out — requires caddy-ratelimit plugin.
    # Uncomment when using a Caddy build that includes it.

    reverse_proxy /signup db:8000
    reverse_proxy /signin db:8000
    reverse_proxy /sql db:8000
    reverse_proxy /rpc db:8000
}
